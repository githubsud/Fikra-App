{
  "hosting": {
    "public": "dist/fikra-stable",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/en-US{,/**}",
        "destination": "/en-US/index.html"
      },
      {
        "source": "**",
        "destination": "/ar/index.html"
      }
    ]
  }
}
